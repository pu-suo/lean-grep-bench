{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://leangrep-bench/schemas/build_manifest.v2.schema.json",
  "title": "lean-grep-bench v2 build manifest",
  "type": "object",
  "required": ["schema_version", "built_at", "projects"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "v2"
    },
    "built_at": {
      "type": "string",
      "format": "date-time"
    },
    "projects": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "project_name",
          "project_repo_url",
          "project_sha",
          "mathlib_sha",
          "lean_toolchain",
          "license",
          "decl_count"
        ],
        "additionalProperties": false,
        "properties": {
          "project_name": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "project_repo_url": {
            "type": "string",
            "format": "uri"
          },
          "project_sha": {
            "type": "string",
            "pattern": "^[0-9a-f]{40}$"
          },
          "mathlib_sha": {
            "type": "string",
            "pattern": "^[0-9a-f]{40}$"
          },
          "lean_toolchain": {
            "type": "string",
            "minLength": 1
          },
          "license": {
            "type": "string",
            "minLength": 1
          },
          "decl_count": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    }
  }
}
