# Mathlib corpus exports — generated, large (>100 MB), regenerable from
# the local Mathlib checkout via `leangrep-bench corpus build-mathlib`
# and `corpus build-union`. The PFR / project-local JSONLs are small
# and stay tracked.
data/corpus/mathlib_declarations.jsonl
data/corpus/mathlib__*.jsonl
data/corpus/union/mathlib__*.jsonl

# Trace logs from full PNT/Carleson/FLT-regular runs — ephemeral.
full_trace_*.log

# LeanDojo trace artifacts — multi-GB, captured on the EC2 trace box and
# rsynced down. Per-project subdir per the v2 runbook.
data/dojo_trace/
data/dojo_trace_*/
